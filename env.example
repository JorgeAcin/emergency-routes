# ============================================
# Emergency Routes - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit the .env file to the repository.

# OpenRouteService API Key
# Get yours at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# Firebase Configuration
# Get yours at: https://console.firebase.google.com/
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Hugging Face Spaces (mBERT triage model)
# The model is publicly hosted; no key needed for inference.
HF_SPACE_URL=https://huggingface.co/spaces/YOUR_SPACE_URL
